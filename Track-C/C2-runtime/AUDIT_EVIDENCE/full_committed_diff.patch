+        half_output = ctypes.create_string_buffer(2)
+        assert runtime.aecCopyH2D(f16a, two, 2) == SUCCESS
+        assert runtime.aecCopyH2D(f16b, three, 2) == SUCCESS
+        stream = ptr()
+        assert runtime.aecStreamCreate(ctypes.byref(stream)) == SUCCESS
