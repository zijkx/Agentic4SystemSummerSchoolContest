+#!/usr/bin/env python3
+"""R203 odd packed INT4, async INT8, and output-span checks."""
+
+from __future__ import annotations
+
+import argparse
+import ctypes
+import struct
+from pathlib import Path
+
+
+SUCCESS = 0
+INVALID_ADDRESS = 4
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
